# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# --- data/ (business state) ---
# Track everything in data/ EXCEPT the items below.

# Inner git repo (auto-created on first run by git-service.ts)
data/.git/
data/.git.bak/

# Agent conversation transcripts (bulky, ephemeral — outputs live in KB/Slack/memory)
data/.agents/.conversations/

# Runtime process state
data/.agents/.runtime/

# Per-user UI state
data/.agents/.slack/.dismissed-alerts.json

# SQLite runtime DB (legacy chat system)
data/.cabinet.db
data/.cabinet.db-shm
data/.cabinet.db-wal

# Legacy chat (replaced by Agent Slack)
data/.chat/

# Job execution logs (runtime, not definitions)
data/.jobs/.history/

# Build artifacts
data/.agents/.library/.next/

# claude code
.claude/
