# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# data dir has its own git repo for content versioning
data/.git/
data/.git.bak/

# user data (created at runtime)
data/.agents/.config/
data/.agents/.history/
data/.agents/.memory/
data/.agents/.messages/
data/.agents/.slack/
data/.agents/.config.json
data/.agents/ceo/
data/.agents/editor/
data/.agents/content-marketer/
data/.agents/
!data/.agents/.library/
data/.chat/
data/.missions/
data/.playbooks/
data/.cabinet.db
data/.cabinet.db-shm
data/.cabinet.db-wal

# user KB content (ship only getting-started template)

# claude code
.claude/

# stray build artifacts
data/.agents/.library/.next/
